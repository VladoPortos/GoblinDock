# Copy to .env and set a long random value (keeps sessions + encrypts stored secrets).
#   python -c "import secrets; print('GOBLINDOCK_SECRET_KEY='+secrets.token_hex(32))" > .env
GOBLINDOCK_SECRET_KEY=change-me-to-a-long-random-string

# Run the container as your host user (for bind-mounted ./data + SSH key):
#   id -u  /  id -g
GD_UID=1000
GD_GID=1000

# Scheduled SQLite backups (WAL-safe online snapshots, rotated). Defaults shown.
# The backup dir defaults to <data>/backups; backups hold the SAME encrypted secrets
# as the live DB and need the matching GOBLINDOCK_SECRET_KEY to restore.
#GOBLINDOCK_BACKUP_ENABLED=1
#GOBLINDOCK_BACKUP_INTERVAL_HOURS=24
#GOBLINDOCK_BACKUP_KEEP=7
#GOBLINDOCK_BACKUP_DIR=/data/backups
